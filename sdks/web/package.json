{
  "name": "@neptune.fintech/astro-web",
  "version": "1.0.0",
  "description": "Drop-in checkout widget for OpenWave payments",
  "type": "module",
  "main": "./dist/astro.umd.js",
  "module": "./dist/astro.js",
  "types": "./dist/astro.d.ts",
  "exports": {
    ".": {
      "types": "./dist/astro.d.ts",
      "import": "./dist/astro.js",
      "require": "./dist/astro.umd.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.json",
    "dev": "vite build --watch",
    "preview": "vite preview"
  },
  "keywords": ["openwave", "astro", "checkout", "payments", "widget"],
  "license": "UNLICENSED",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.0.0"
  }
}
